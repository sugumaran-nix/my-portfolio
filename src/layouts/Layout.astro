---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Sugumaran S — Full-Stack Developer' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="font-sans text-[15px] leading-[1.6] overflow-x-hidden">
    <slot />
  </body>
</html>
