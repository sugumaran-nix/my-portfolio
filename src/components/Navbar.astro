---
import ThemeToggle from './ThemeToggle.jsx';

const links = [
  { href: '#home',      label: 'Home' },
  { href: '#about',     label: 'About' },
  { href: '#skills',    label: 'Skills' },
  { href: '#education', label: 'Education' },
  { href: '#projects',  label: 'Projects' },
  { href: '#contact',   label: 'Contact' },
];
---

<nav class="sticky top-0 z-50 bg-surface/80 dark:bg-surfaceDark/80 backdrop-blur-xl border-b border-borderLight dark:border-borderDark">
  <div class="flex items-center justify-between px-6 md:px-10 py-4">
    <a href="#home" class="text-[17px] font-bold tracking-tight">
      <span class="text-accent dark:text-accentDark">Sugumaran</span><span class="text-inkMuted dark:text-white/40"> S</span>
    </a>

    <ul class="hidden md:flex items-center gap-8 list-none">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm text-inkMuted dark:text-white/70 hover:text-ink dark:hover:text-white transition-all duration-150 hover:scale-105 inline-block"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-3">
      <ThemeToggle client:load />

      <button
        id="mobile-menu-btn"
        aria-label="Toggle menu"
        aria-expanded="false"
        class="md:hidden flex items-center justify-center w-9 h-9 rounded-lg text-ink dark:text-white hover:bg-black/5 dark:hover:bg-white/5 transition-colors"
      >
        <svg id="icon-hamburger" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5">
          <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round" />
        </svg>
        <svg id="icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 hidden">
          <path d="M18 6L6 18M6 6l12 12" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <ul
    id="mobile-menu"
    class="hidden md:hidden flex-col list-none border-t border-borderLight dark:border-borderDark px-6 py-3"
  >
    {links.map((link) => (
      <li>
        <a
          href={link.href}
          class="mobile-menu-link block py-3 text-base text-inkMuted dark:text-white/70 hover:text-ink dark:hover:text-white transition-colors"
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconHamburger = document.getElementById('icon-hamburger');
  const iconClose = document.getElementById('icon-close');

  function closeMenu() {
    mobileMenu?.classList.add('hidden');
    mobileMenu?.classList.remove('flex');
    iconHamburger?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    menuBtn?.setAttribute('aria-expanded', 'false');
  }

  function toggleMenu() {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    if (isOpen) {
      closeMenu();
    } else {
      mobileMenu?.classList.remove('hidden');
      mobileMenu?.classList.add('flex');
      iconHamburger?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      menuBtn?.setAttribute('aria-expanded', 'true');
    }
  }

  menuBtn?.addEventListener('click', toggleMenu);
  document.querySelectorAll('.mobile-menu-link').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });
</script>
