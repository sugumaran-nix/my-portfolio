---
const links = [
  { href: '#about', label: 'About' },
  { href: '#projects', label: 'Projects' },
  { href: '#skills', label: 'Skills' },
  { href: '#contact', label: 'Contact' },
];
---

<nav class="fixed top-0 left-0 right-0 z-[100] flex items-center justify-between px-6 md:px-12 py-4 md:py-5 bg-bg/90 backdrop-blur-md border-b border-border">
  <a class="font-mono text-[13px] font-bold tracking-wide text-white" href="#">SUGUMARAN S</a>

  <ul class="hidden md:flex gap-9 list-none">
    {links.map((link) => (
      <li>
        <a
          href={link.href}
          class="font-mono text-xs text-textMuted uppercase tracking-wider transition-colors hover:text-white"
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>

  <a
    class="font-mono text-xs px-5 py-2.5 bg-white text-bg rounded-full transition-opacity hover:opacity-85"
    href="#contact"
  >
    Hire Me
  </a>
</nav>
