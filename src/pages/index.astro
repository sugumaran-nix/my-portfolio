---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.jsx';
import ContactForm from '../components/ContactForm.jsx';

// Skills redesigned as arrays for chip/tag rendering
const skillGroups = [
  {
    title: 'Languages',
    skills: ['Python (Primary)', 'JavaScript (ES6+)', 'TypeScript', 'SQL'],
  },
  {
    title: 'Frontend',
    skills: ['React.js', 'Next.js', 'HTML5', 'CSS3', 'Tailwind CSS'],
  },
  {
    title: 'Backend',
    skills: ['FastAPI', 'Flask', 'WebSockets', 'REST API Design'],
  },
  {
    title: 'Databases',
    skills: ['MySQL', 'SQLite', 'MongoDB'],
  },
  {
    title: 'Tools & OS',
    skills: ['Git', 'GitHub', 'VS Code', 'Linux', 'Jupyter Notebook'],
  },
  {
    title: 'AI / ML & NLP',
    skills: ['Scikit-learn', 'TF-IDF', 'NLP', 'Hugging Face Transformers', 'BERT', 'LLM Prompt Engineering'],
  },
];

const projects = [
  {
    image: 'https://images.unsplash.com/photo-1488229297570-58520851e868?w=800&q=80',
    title: 'ML-Powered Fake Job Detector',
    desc: 'Benchmarked 4 ML classifiers on 17,880 real-world job postings to detect fraudulent listings. Best-class Fraud F1-score: 87.57% on a heavily imbalanced dataset (4.8% fraud rate). Features a 10,000-feature bigram TF-IDF pipeline, SHAP-style explainability, runtime model switching, and SQLite-backed prediction history. Sub-800ms end-to-end API response.',
    tags: ['Python', 'Scikit-learn', 'NLP', 'Flask', 'Explainable AI'],
    href: 'https://github.com/sugumaran-nix/fake-job-posting-ml',
    demoHref: 'https://fake-job-posting-ml.onrender.com',
  },
  {
    image: 'https://images.unsplash.com/photo-1455390582262-044cdead277a?w=800&q=80',
    title: 'AI-Generated Text Detector',
    desc: 'Statistical classifier distinguishing human-written from AI-generated text using perplexity, burstiness, and sentence-level variance. Sentence-level explainability highlights exact text spans flagged as machine-generated. Served via FastAPI returning structured JSON with per-sentence confidence scores.',
    tags: ['Python', 'FastAPI', 'NLP', 'Explainable AI'],
    href: 'https://github.com/sugumaran-nix/ai-content-detector',
    demoHref: 'https://ai-content-detector-ecru-two.vercel.app/',
  },
  {
    image: 'https://images.unsplash.com/photo-1611532736597-de2d4265fba3?w=800&q=80',
    title: 'Sketchline — Real-Time Collaborative Whiteboard',
    desc: 'Full-stack multiplayer whiteboard built from scratch. FastAPI WebSocket backend manages room state, stroke history, and multi-client broadcast via a custom 7-message-type JSON protocol. Sub-100ms stroke sync latency, full board-state replay on reconnect, live cursor presence at 20 updates/sec. Frontend on Vercel, backend on Railway via Dockerfile.',
    tags: ['FastAPI', 'WebSockets', 'Next.js', 'TypeScript', 'HTML5 Canvas'],
    href: 'https://github.com/sugumaran-nix/Sketchline-whiteboard',
    demoHref: 'https://whiteboard-frontend-nine-smoky.vercel.app',
  },
  {
    image: 'https://images.unsplash.com/photo-1677506048148-0c914dd8197b?w=800&q=80',
    title: 'ProjectScope — Eisenhower Matrix Task Manager',
    desc: 'Fully responsive drag-and-drop task manager built in React.js and TypeScript. Quadrant-based prioritisation using dnd-kit, keyboard-accessible interactions, and cross-tab localStorage state sync for a persistent, backend-free experience.',
    tags: ['React.js', 'TypeScript', 'Tailwind CSS', 'dnd-kit'],
    href: 'https://github.com/sugumaran-nix/ProjectScope',
    demoHref: 'https://project-scope-seven.vercel.app',
  },
];

const socials = [
  {
    label: 'GitHub',
    href: 'https://github.com/sugumaran-nix',
    icon: 'M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.38.6.1.82-.26.82-.58v-2.03c-3.34.72-4.04-1.61-4.04-1.61-.54-1.38-1.33-1.75-1.33-1.75-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 013-.4c1.02 0 2.04.13 3 .4 2.28-1.55 3.29-1.23 3.29-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.21.69.82.57C20.56 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z',
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/sugumaran-nix',
    icon: 'M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 110-4.14 2.07 2.07 0 010 4.14zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.8 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z',
  },
  {
    label: 'Email',
    href: 'mailto:sugumarankugan@gmail.com',
    icon: 'M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z',
  },
];
---

<Layout>
  <Navbar />

  <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
  <section id="home" class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 py-24">
    <div class="reveal max-w-[600px] mx-auto w-full">

      <!-- Name — largest -->
      <h1 class="text-[36px] sm:text-[48px] md:text-[68px] font-bold leading-[1.05] tracking-tight mb-3">
        Hii, I'm Sugumaran
      </h1>

      <!-- Role — medium -->
      <p class="text-lg sm:text-xl md:text-2xl font-medium text-inkMuted dark:text-white/70 mb-5">
        Software Developer
      </p>

      <!-- Description — smallest, tighter width, more line height -->
      <p class="max-w-[480px] mx-auto text-sm sm:text-base text-inkMuted dark:text-white/60 leading-[1.75] mb-10 px-2">
        I build and ship AI/ML models and full-stack web apps — fraud detectors, text classifiers,
        and real-time collaborative tools. Python · FastAPI · React.js. All deployed and live.
      </p>

      <!-- CTAs — tighter gap between buttons, more space from description handled by mb-10 above -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-2 sm:gap-3 mb-6">
        <a
          href="/sugumaran-s-resume.pdf"
          download
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 text-sm font-semibold px-7 py-3 h-[44px] rounded-xl bg-accent dark:bg-accentDark text-white dark:text-black transition-all duration-150 hover:bg-accentHover dark:hover:opacity-90 shadow-card hover:scale-105"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 flex-shrink-0">
            <path d="M12 3v12m0 0l-4-4m4 4l4-4M4 19h16" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          Download CV
        </a>
        <a
          href="#contact"
          id="git-btn-hero"
          class="git-btn w-full sm:w-auto inline-flex items-center justify-center text-sm font-semibold px-7 py-3 h-[44px]"
        >
          Get In Touch
        </a>
      </div>

      <!-- Social icons — closer to buttons, larger icons, even gap -->
      <div class="flex items-center justify-center gap-5">
        {socials.map((s) => (
          <a
            href={s.href}
            target={s.href.startsWith('http') ? '_blank' : undefined}
            rel={s.href.startsWith('http') ? 'noopener' : undefined}
            aria-label={s.label}
            title={s.label}
            class="text-inkMuted dark:text-white/50 hover:text-ink dark:hover:text-white transition-colors"
          >
            <svg viewBox="0 0 24 24" class="w-[22px] h-[22px] fill-current"><path d={s.icon}></path></svg>
          </a>
        ))}
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 text-inkMuted/40 dark:text-white/25 animate-bounce pointer-events-none select-none">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5">
        <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>
  </section>

  <!-- ─── ABOUT ─────────────────────────────────────────────────────────── -->
  <section id="about" class="bg-surfaceMuted dark:bg-surfaceDarkMuted px-6 md:px-10 py-10 md:py-16">
    <div class="max-w-[1100px] mx-auto">

      <div class="reveal mb-6 md:mb-10">
        <h2 class="text-2xl sm:text-3xl md:text-[42px] font-bold tracking-tight">About Me</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-12 items-start">

        <!-- Profile card — shows first on mobile via order, second on desktop -->
        <div class="reveal order-first md:order-last" style="transition-delay: 0.1s">
          <div class="rounded-xl border border-white/10 dark:border-white/5 bg-white/60 dark:bg-white/[0.04] backdrop-blur-md shadow-[0_2px_12px_-2px_rgba(0,0,0,0.08),0_0_0_1px_rgba(0,0,0,0.04)] dark:shadow-[inset_0_1px_0_0_rgba(255,255,255,0.06),0_0_0_1px_#262626] p-6 text-center flex flex-col items-center">
            <div class="w-40 h-40 mx-auto rounded-full overflow-hidden ring-2 ring-borderLight dark:ring-borderDark mb-4">
              <img src="/profile.jpg" alt="Sugumaran S" class="w-full h-full object-cover" />
            </div>
            <h4 class="text-lg font-semibold mb-1">Sugumaran</h4>
            <p class="text-sm text-inkMuted dark:text-white/60 mb-1">Software Developer</p>
            <p class="text-sm text-inkMuted dark:text-white/60 mb-4">Based in Coimbatore, Tamil Nadu</p>
            <div class="flex flex-wrap justify-center gap-2">
              <span class="inline-flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-full border border-borderLight dark:border-borderDark text-inkMuted dark:text-white/60">
                <span class="w-1.5 h-1.5 rounded-full bg-ink dark:bg-white/60 animate-pulse"></span>
                Available Immediately
              </span>
              <span class="inline-flex items-center text-xs font-medium px-3 py-1.5 rounded-full border border-borderLight dark:border-borderDark text-inkMuted dark:text-white/60">
                Remote · Open to Relocation
              </span>
            </div>
          </div>
        </div>

        <!-- Text column — shows second on mobile, first on desktop -->
        <div class="reveal order-last md:order-first flex flex-col gap-4 text-sm text-inkMuted dark:text-white/60 leading-[1.85] text-justify">
          <p>
            Recent MCA Graduate (2026) from Anna University, Coimbatore. I build AI/ML systems and full-stack web applications end-to-end — from data preprocessing and model training to REST API deployment and React frontends.
          </p>
          <p>
            Open to AI/ML Engineer, Full Stack Developer, and Data Annotation Specialist roles. Available immediately, open to relocation anywhere in India and remote work.
          </p>
          <div class="flex flex-col gap-2 mt-2 border-t border-borderLight dark:border-borderDark pt-5">
            <div class="flex flex-col gap-0.5">
              <p class="text-xs font-semibold text-ink dark:text-white uppercase tracking-wider mb-1">Education</p>
              <p class="text-sm">MCA — Anna University <span class="text-inkMuted/70 dark:text-white/40">(Sri Venkateshwara College of Computer Applications and Management)</span></p>
              <p class="text-xs text-inkMuted/70 dark:text-white/40">2024–2026 · Score: 80%</p>
            </div>
            <div class="flex flex-col gap-0.5 mt-2">
              <p class="text-sm">BCA — Bharathiar University <span class="text-inkMuted/70 dark:text-white/40">(Govt Arts & Science College, Gudalur)</span></p>
              <p class="text-xs text-inkMuted/70 dark:text-white/40">2021–2024 · Score: 83.71%</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ─── SKILLS ────────────────────────────────────────────────────────── -->
  <!--
    Layout variation: left-aligned title + chip/tag rows instead of card grid.
    Breaks the "stacked identical centered blocks" pattern.
  -->
  <section id="skills" class="px-6 md:px-10 py-10 md:py-16">
    <div class="max-w-[1100px] mx-auto">

      <div class="reveal mb-6 md:mb-10">
        <h2 class="text-2xl sm:text-3xl md:text-[42px] font-bold tracking-tight">Skills & Technologies</h2>
      </div>

      <div class="reveal flex flex-col divide-y divide-borderLight dark:divide-borderDark border border-borderLight dark:border-borderDark rounded-xl overflow-hidden" style="transition-delay: 0.1s">
        {skillGroups.map((group) => (
          <div class="flex flex-col sm:grid sm:grid-cols-[160px_1fr] items-start gap-3 sm:gap-6 px-5 py-4 sm:px-6 sm:py-5">
            <p class="text-[10px] sm:text-xs font-semibold uppercase tracking-widest text-inkMuted/60 dark:text-white/35 sm:pt-1">
              {group.title}
            </p>
            <div class="flex flex-wrap gap-2">
              {group.skills.map((skill) => (
                <span class="text-xs sm:text-sm px-2.5 sm:px-3 py-1 sm:py-1.5 rounded-lg bg-black/[0.04] dark:bg-white/[0.07] text-ink dark:text-white/85 border border-borderLight dark:border-borderDark">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ─── PROJECTS ──────────────────────────────────────────────────────── -->
  <section id="projects" class="bg-surfaceMuted dark:bg-surfaceDarkMuted px-6 md:px-10 py-10 md:py-16">
    <div class="max-w-[1100px] mx-auto">

      <div class="reveal mb-6 md:mb-10">
        <h2 class="text-2xl sm:text-3xl md:text-[42px] font-bold tracking-tight">Featured Projects</h2>
      </div>

      <div class="reveal grid grid-cols-1 sm:grid-cols-2 gap-5">
        {projects.map((p, i) => (
          <ProjectCard client:visible {...p} delay={i * 0.08} />
        ))}
      </div>

      <div class="flex justify-center mt-12">
        <a
          href="https://github.com/sugumaran-nix"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 text-sm font-medium px-6 py-2.5 rounded-xl border border-borderLight dark:border-borderDark text-ink dark:text-white transition-colors hover:bg-black/5 dark:hover:bg-white/5"
        >
          <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.38.6.1.82-.26.82-.58v-2.03c-3.34.72-4.04-1.61-4.04-1.61-.54-1.38-1.33-1.75-1.33-1.75-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 013-.4c1.02 0 2.04.13 3 .4 2.28-1.55 3.29-1.23 3.29-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.21.69.82.57C20.56 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z" />
          </svg>
          View All Projects on GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- ─── CONTACT ───────────────────────────────────────────────────────── -->
  <section id="contact" class="px-6 md:px-10 py-10 md:py-16">
    <div class="max-w-[1100px] mx-auto">

      <div class="reveal mb-6 md:mb-10">
        <h2 class="text-2xl sm:text-3xl md:text-[42px] font-bold tracking-tight">Get In Touch</h2>
      </div>

      <!--
        3-column grid: [info] [1px divider] [form]
        Divider creates a structural relationship between the two sides.
      -->
      <div class="grid grid-cols-1 md:grid-cols-[1fr_1px_1fr] gap-10 md:gap-0 items-start">

        <!-- Contact form — first on mobile, right on desktop -->
        <div class="reveal order-first md:order-last md:pl-12" style="transition-delay: 0.1s">
          <ContactForm client:visible />
        </div>

        <!-- Vertical divider — visible on md+ -->
        <div class="hidden md:block self-stretch bg-borderLight dark:bg-borderDark order-2"></div>

        <!-- Contact info — second on mobile, left on desktop -->
        <div class="reveal order-last md:order-first md:pr-12">
          <h3 class="text-lg font-semibold mb-6">Contact Information</h3>
          <div class="flex flex-col gap-5 mb-8">
            <div class="flex items-start gap-3.5">
              <div class="w-9 h-9 rounded-lg bg-black/5 dark:bg-white/10 flex items-center justify-center flex-shrink-0">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                  <path d="M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 4l-8 5-8-5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold mb-0.5">Email</p>
                <a href="mailto:sugumarankugan@gmail.com" class="text-sm text-inkMuted dark:text-white/60 hover:text-ink dark:hover:text-white transition-colors">
                  sugumarankugan@gmail.com
                </a>
              </div>
            </div>
            <div class="flex items-start gap-3.5">
              <div class="w-9 h-9 rounded-lg bg-black/5 dark:bg-white/10 flex items-center justify-center flex-shrink-0">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1118 0z" stroke-linecap="round" stroke-linejoin="round" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold mb-0.5">Location</p>
                <p class="text-sm text-inkMuted dark:text-white/60">Coimbatore, Tamil Nadu</p>
              </div>
            </div>
          </div>
          <h4 class="text-base font-semibold mb-2">Let's Connect</h4>
          <p class="text-sm text-inkMuted dark:text-white/60 leading-relaxed mb-6 max-w-[380px]">
            Whether you have an opening, a project in mind, or just want to talk tech, I'd love to hear from you.
          </p>
          <div class="flex flex-col gap-3">
            {socials.map((s) => (
              <a
                href={s.href}
                target={s.href.startsWith('http') ? '_blank' : undefined}
                rel={s.href.startsWith('http') ? 'noopener' : undefined}
                class="inline-flex items-center gap-3 text-sm text-inkMuted dark:text-white/60 hover:text-ink dark:hover:text-white transition-colors group"
              >
                <span class="w-8 h-8 rounded-lg border border-borderLight dark:border-borderDark flex items-center justify-center group-hover:border-ink/20 dark:group-hover:border-white/20 transition-colors flex-shrink-0">
                  <svg viewBox="0 0 24 24" class="w-[15px] h-[15px] fill-current"><path d={s.icon}></path></svg>
                </span>
                {s.label}
              </a>
            ))}
            <a
              href="/sugumaran-s-resume.pdf"
              download
              class="inline-flex items-center gap-2 mt-3 text-sm font-medium px-5 py-2.5 rounded-xl bg-accent dark:bg-accentDark text-white dark:text-black transition-all duration-150 hover:bg-accentHover dark:hover:opacity-90 shadow-card hover:scale-105 w-fit"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                <path d="M12 3v12m0 0l-4-4m4 4l4-4M4 19h16" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              Download CV
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer />

  <script>
    // Reset git-btn hover state after click navigation
    const gitBtn = document.getElementById('git-btn-hero');
    if (gitBtn) {
      gitBtn.addEventListener('click', () => {
        gitBtn.blur();
        // Force reflow to reset pseudo-element animation
        setTimeout(() => {
          gitBtn.classList.remove('git-btn-active');
          void gitBtn.offsetWidth;
        }, 600);
      });
    }
  </script>
</Layout>
