---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.jsx';
import ContactForm from '../components/ContactForm.jsx';

const skillGroups = [
  {
    title: 'Languages',
    description: 'Python (Primary), JavaScript (ES6+), TypeScript, SQL',
  },
  {
    title: 'Frontend Development',
    description: 'React.js, HTML5, CSS3, Next.js, Tailwind CSS',
  },
  {
    title: 'Backend Development',
    description: 'FastAPI, Flask, WebSockets, REST API Design',
  },
  {
    title: 'Database Management',
    description: 'MySQL, SQLite, MongoDB',
  },
  {
    title: 'Tools & OS',
    description: 'Git, GitHub, VS Code, Linux, Jupyter Notebook',
  },
  {
    title: 'AI/ML & NLP',
    description: 'Scikit-learn, TF-IDF, NLP, Hugging Face Transformers, BERT, LLM Prompt Engineering',
  },
];

const projects = [
  {
    image: 'https://images.unsplash.com/photo-1488229297570-58520851e868?w=800&q=80',
    title: 'ML-Powered Fake Job Detector',
    desc: 'Benchmarked 4 ML classifiers on 17,880 real-world job postings to detect fraudulent listings. Best-class Fraud F1-score: 87.57% on a heavily imbalanced dataset (4.8% fraud rate). Features a 10,000-feature bigram TF-IDF pipeline, SHAP-style explainability, runtime model switching, and SQLite-backed prediction history. Sub-800ms end-to-end API response.',
    tags: ['Python', 'Scikit-learn', 'NLP', 'Flask', 'Explainable AI'],
    href: 'https://github.com/sugumaran-nix/fake-job-posting-ml',
    demoHref: 'https://fake-job-posting-ml.onrender.com',
  },
  {
    image: 'https://images.unsplash.com/photo-1455390582262-044cdead277a?w=800&q=80',
    title: 'AI-Generated Text Detector',
    desc: 'Statistical classifier distinguishing human-written from AI-generated text using perplexity, burstiness, and sentence-level variance. Sentence-level explainability highlights exact text spans flagged as machine-generated. Served via FastAPI returning structured JSON with per-sentence confidence scores.',
    tags: ['Python', 'FastAPI', 'NLP', 'Explainable AI'],
    href: 'https://github.com/sugumaran-nix/ai-content-detector',
    demoHref: 'https://ai-content-detector-ecru-two.vercel.app/',
  },
  {
    image: 'https://images.unsplash.com/photo-1611532736597-de2d4265fba3?w=800&q=80',
    title: 'Sketchline — Real-Time Collaborative Whiteboard',
    desc: 'Full-stack multiplayer whiteboard built from scratch. FastAPI WebSocket backend manages room state, stroke history, and multi-client broadcast via a custom 7-message-type JSON protocol. Sub-100ms stroke sync latency, full board-state replay on reconnect, live cursor presence at 20 updates/sec. Frontend on Vercel, backend on Railway via Dockerfile.',
    tags: ['FastAPI', 'WebSockets', 'Next.js', 'TypeScript', 'HTML5 Canvas'],
    href: 'https://github.com/sugumaran-nix/Sketchline-whiteboard',
    demoHref: 'https://whiteboard-frontend-nine-smoky.vercel.app',
  },
  {
    image: 'https://images.unsplash.com/photo-1677506048148-0c914dd8197b?w=800&q=80',
    title: 'ProjectScope — Eisenhower Matrix Task Manager',
    desc: 'Fully responsive drag-and-drop task manager built in React.js and TypeScript. Quadrant-based prioritisation using dnd-kit, keyboard-accessible interactions, and cross-tab localStorage state sync for a persistent, backend-free experience.',
    tags: ['React.js', 'TypeScript', 'Tailwind CSS', 'dnd-kit'],
    href: 'https://github.com/sugumaran-nix/ProjectScope',
    demoHref: 'https://project-scope-seven.vercel.app',
  },
];

const socials = [
  { label: 'GitHub', href: 'https://github.com/sugumaran-nix', icon: 'M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.38.6.1.82-.26.82-.58v-2.03c-3.34.72-4.04-1.61-4.04-1.61-.54-1.38-1.33-1.75-1.33-1.75-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 013-.4c1.02 0 2.04.13 3 .4 2.28-1.55 3.29-1.23 3.29-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.21.69.82.57C20.56 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/sugumaran-nix', icon: 'M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 110-4.14 2.07 2.07 0 010 4.14zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.8 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z' },
  { label: 'Email', href: 'mailto:sugumarankugan@gmail.com', icon: 'M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z' },
];
---

<Layout>
  <Navbar />

  <!-- HOME / HERO -->
  <section id="home" class="min-h-[88vh] flex flex-col items-center justify-center text-center px-6 py-20">
    <div class="reveal">
      <h1 class="text-[44px] md:text-[64px] font-bold leading-[1.05] tracking-tight mb-3">
        I'm Sugumaran
      </h1>
      <p class="text-lg md:text-2xl font-medium text-inkMuted dark:text-white/70 mb-6">
        Software Developer
      </p>
      <p class="max-w-[560px] mx-auto text-base text-inkMuted dark:text-white/60 leading-relaxed mb-9">
        I build and ship AI/ML models and full-stack web apps — fraud detectors, text classifiers,
        and real-time collaborative tools. Python · FastAPI · React.js. All deployed and live.
      </p>

      <div class="flex items-center justify-center gap-3 mb-9">
        <a href="/sugumaran-s-resume.pdf" download class="text-sm font-medium px-6 py-2.5 rounded-lg bg-accent dark:bg-accentDark text-white transition-all duration-150 hover:bg-accentHover dark:hover:opacity-90 shadow-card hover:scale-105">
          Download CV
        </a>
        <a href="#contact" class="text-sm font-medium px-6 py-2.5 rounded-lg border border-borderLight dark:border-borderDark text-ink dark:text-white transition-colors hover:bg-black/5 dark:hover:bg-white/5">
          Get In Touch
        </a>
      </div>

      <div class="flex items-center justify-center gap-5">
        {socials.map((s) => (
          <a
            href={s.href}
            target={s.href.startsWith('http') ? '_blank' : undefined}
            rel={s.href.startsWith('http') ? 'noopener' : undefined}
            aria-label={s.label}
            class="text-inkMuted dark:text-white/60 hover:text-ink dark:hover:text-white transition-colors"
          >
            <svg viewBox="0 0 24 24" class="w-[18px] h-[18px] fill-current"><path d={s.icon}></path></svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="bg-surfaceMuted dark:bg-surfaceDarkMuted px-6 md:px-10 py-20">
    <div class="reveal text-center mb-14">
      <h2 class="text-3xl md:text-[42px] font-bold tracking-tight mb-4">About Me</h2>
      <p class="max-w-[640px] mx-auto text-base text-inkMuted dark:text-white/60 leading-relaxed">
        A software developer building AI/ML systems and full-stack web apps — all deployed and live.
      </p>
    </div>

    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 items-stretch">
      <div class="reveal">
        <div class="flex flex-col gap-4 text-sm text-inkMuted dark:text-white/60 leading-[1.8]">
          <p>
            Recent MCA Graduate (2026) from Anna University, Coimbatore. I build AI/ML systems
            and full-stack web applications end-to-end — from data preprocessing and model training
            to REST API deployment and React frontends.
          </p>
          <p>
            I've shipped a fraud detection ML model with an 87.57% F1-score, an AI-generated text
            classifier, a real-time multiplayer whiteboard with sub-100ms WebSocket latency, and a
            drag-and-drop task manager — all deployed and live.
          </p>
          <p>
            Open to AI/ML Engineer, Full Stack Developer, and Data Annotation Specialist roles.
            Available immediately. Open to relocation anywhere in India and remote work.
          </p>
          <div class="mt-2 flex flex-col gap-1.5 text-xs text-inkMuted dark:text-white/50 border-t border-borderLight dark:border-borderDark pt-4">
            <p>MCA — Anna University (Sri Venkateshwara College of Computer Applications and Management), 2024–2026 · Score: 80%</p>
            <p>BCA — Bharathiar University (Govt Arts & Science College, Gudalur), 2021–2024 · Score: 83.71%</p>
          </div>
        </div>
      </div>

      <div class="reveal h-full" style="transition-delay: 0.1s">
        <div class="h-full rounded-xl border border-borderLight dark:border-borderDark bg-cardLight dark:bg-cardDark shadow-card dark:shadow-cardDark p-8 md:p-10 text-center flex flex-col items-center justify-center">
          <div class="w-20 h-20 mx-auto rounded-full bg-black/5 dark:bg-white/10 flex items-center justify-center mb-6">
           
          <img src="/profile.jpg" alt="Sugumaran S" class="w-full h-full object-cover rounded-full" />

<!-- <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-9 h-9">
              <path d="M16 18l6-6-6-6M8 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
-->

          </div>
          <h4 class="text-lg font-semibold mb-1">Sugumaran S</h4>
          <p class="text-sm text-inkMuted dark:text-white/60 mb-5">Software Developer</p>
          <p class="text-sm text-inkMuted dark:text-white/60">Based in Coimbatore, Tamil Nadu</p>
          <p class="text-sm text-inkMuted dark:text-white/60">Open to full-time opportunities</p>
          <p class="text-sm text-inkMuted dark:text-white/60">Remote · Open to Relocation</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SKILLS -->
  <section id="skills" class="px-6 md:px-10 py-20">
    <div class="reveal text-center mb-14">
      <h2 class="text-3xl md:text-[42px] font-bold tracking-tight mb-4">Skills & Technologies</h2>
      <p class="max-w-[640px] mx-auto text-base text-inkMuted dark:text-white/60 leading-relaxed">
        The tools and technologies I use to design, build, and ship AI/ML systems and full-stack applications.
      </p>
    </div>

    <div class="max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
      <!-- Languages -->
      <div class="reveal rounded-xl border border-borderLight dark:border-borderDark bg-cardLight dark:bg-cardDark shadow-card dark:shadow-cardDark p-6 min-h-[180px] transition-transform duration-150 hover:scale-[1.015]" style="transition-delay: 0s">
        <div class="w-11 h-11 rounded-full bg-black/5 dark:bg-white/10 flex items-center justify-center mb-4">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-ink dark:text-white">
            <path d="M9 6l-5 6 5 6M15 6l5 6-5 6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <h4 class="text-base font-semibold mb-1.5">{skillGroups[0].title}</h4>
        <p class="text-sm text-inkMuted dark:text-white/60 leading-relaxed">{skillGroups[0].description}</p>
      </div>

      <!-- Frontend -->
      <div class="reveal rounded-xl border border-borderLight dark:border-borderDark bg-cardLight dark:bg-cardDark shadow-card dark:shadow-cardDark p-6 min-h-[180px] transition-transform duration-150 hover:scale-[1.015]" style="transition-delay: 0.05s">
        <div class="w-11 h-11 rounded-full bg-black/5 dark:bg-white/10 flex items-center justify-center mb-4">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-ink dark:text-white">
            <rect x="3" y="4" width="18" height="16" rx="2" stroke-linejoin="round" />
            <path d="M3 9h18" stroke-linecap="round" />
          </svg>
        </div>
        <h4 class="text-base font-semibold mb-1.5">{skillGroups[1].title}</h4>
        <p class="text-sm text-inkMuted dark:text-white/60 leading-relaxed">{skillGroups[1].description}</p>
      </div>

      <!-- Backend -->
      <div class="reveal rounded-xl border border-borderLight dark:border-borderDark bg-cardLight dark:bg-cardDark shadow-card dark:shadow-cardDark p-6 min-h-[180px] transition-transform duration-150 hover:scale-[1.015]" style="transition-delay: 0.1s">
        <div class="w-11 h-11 rounded-full bg-black/5 dark:bg-white/10 flex items-center justify-center mb-4">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-ink dark:text-white">
            <rect x="3" y="4" width="18" height="6" rx="1.5" />
            <rect x="3" y="14" width="18" height="6" rx="1.5" />
            <path d="M7 7h.01M7 17h.01" stroke-linecap="round" />
          </svg>
        </div>
        <h4 class="text-base font-semibold mb-1.5">{skillGroups[2].title}</h4>
        <p class="text-sm text-inkMuted dark:text-white/60 leading-relaxed">{skillGroups[2].description}</p>
      </div>

      <!-- Databases -->
      <div class="reveal rounded-xl border border-borderLight dark:border-borderDark bg-cardLight dark:bg-cardDark shadow-card dark:shadow-cardDark p-6 min-h-[180px] transition-transform duration-150 hover:scale-[1.015]" style="transition-delay: 0.15s">
        <div class="w-11 h-11 rounded-full bg-black/5 dark:bg-white/10 flex items-center justify-center mb-4">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-ink dark:text-white">
            <ellipse cx="12" cy="5" rx="8" ry="3" />
            <path d="M4 5v6c0 1.66 3.58 3 8 3s8-1.34 8-3V5M4 11v6c0 1.66 3.58 3 8 3s8-1.34 8-3v-6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <h4 class="text-base font-semibold mb-1.5">{skillGroups[3].title}</h4>
        <p class="text-sm text-inkMuted dark:text-white/60 leading-relaxed">{skillGroups[3].description}</p>
      </div>

      <!-- Tools & OS -->
      <div class="reveal rounded-xl border border-borderLight dark:border-borderDark bg-cardLight dark:bg-cardDark shadow-card dark:shadow-cardDark p-6 min-h-[180px] transition-transform duration-150 hover:scale-[1.015]" style="transition-delay: 0.2s">
        <div class="w-11 h-11 rounded-full bg-black/5 dark:bg-white/10 flex items-center justify-center mb-4">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-ink dark:text-white">
            <rect x="3" y="4" width="18" height="16" rx="2" />
            <path d="M7 9l3 3-3 3M13 15h4" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <h4 class="text-base font-semibold mb-1.5">{skillGroups[4].title}</h4>
        <p class="text-sm text-inkMuted dark:text-white/60 leading-relaxed">{skillGroups[4].description}</p>
      </div>

      <!-- AI/ML & NLP -->
      <div class="reveal rounded-xl border border-borderLight dark:border-borderDark bg-cardLight dark:bg-cardDark shadow-card dark:shadow-cardDark p-6 min-h-[180px] transition-transform duration-150 hover:scale-[1.015]" style="transition-delay: 0.25s">
        <div class="w-11 h-11 rounded-full bg-black/5 dark:bg-white/10 flex items-center justify-center mb-4">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 text-ink dark:text-white">
            <circle cx="6" cy="6" r="2.5" />
            <circle cx="18" cy="6" r="2.5" />
            <circle cx="12" cy="18" r="2.5" />
            <path d="M8.5 6h7M8.2 7.3L10.5 15.5M15.8 7.3L13.5 15.5" stroke-linecap="round" />
          </svg>
        </div>
        <h4 class="text-base font-semibold mb-1.5">{skillGroups[5].title}</h4>
        <p class="text-sm text-inkMuted dark:text-white/60 leading-relaxed">{skillGroups[5].description}</p>
      </div>
    </div>
  </section>

  <!-- PROJECTS -->
  <section id="projects" class="bg-surfaceMuted dark:bg-surfaceDarkMuted px-6 md:px-10 py-20">
    <div class="reveal text-center mb-14">
      <h2 class="text-3xl md:text-[42px] font-bold tracking-tight mb-4">Featured Projects</h2>
      <p class="max-w-[640px] mx-auto text-base text-inkMuted dark:text-white/60 leading-relaxed">
        A selection of projects I've built — from machine learning systems to deployable AI-integrated platforms.
      </p>
    </div>

    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map((p, i) => (
        <ProjectCard client:visible {...p} delay={i * 0.08} />
      ))}
    </div>

    <div class="flex justify-center mt-10">
      <a
        href="https://github.com/sugumaran-nix"
        target="_blank"
        rel="noopener"
        class="text-sm font-medium px-6 py-2.5 rounded-lg border border-borderLight dark:border-borderDark text-ink dark:text-white transition-colors hover:bg-black/5 dark:hover:bg-white/5"
      >
        View All Projects on GitHub
      </a>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="px-6 md:px-10 py-20">
    <div class="reveal text-center mb-14">
      <h2 class="text-3xl md:text-[42px] font-bold tracking-tight mb-4">Get In Touch</h2>
      <p class="max-w-[640px] mx-auto text-base text-inkMuted dark:text-white/60 leading-relaxed">
        I'm currently looking for full-time opportunities. Reach out if you'd like to talk.
      </p>
    </div>

    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
      <div class="reveal">
        <h3 class="text-lg font-semibold mb-5">Contact Information</h3>
        <div class="flex flex-col gap-5 mb-8">
          <div class="flex items-start gap-3.5">
            <div class="w-9 h-9 rounded-lg bg-black/5 dark:bg-white/10 flex items-center justify-center flex-shrink-0">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                <path d="M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 4l-8 5-8-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold">Email</p>
              <a href="mailto:sugumarankugan@gmail.com" class="text-sm text-inkMuted dark:text-white/60 hover:text-ink dark:hover:text-white transition-colors">sugumarankugan@gmail.com</a>
            </div>
          </div>

          <div class="flex items-start gap-3.5">
            <div class="w-9 h-9 rounded-lg bg-black/5 dark:bg-white/10 flex items-center justify-center flex-shrink-0">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1118 0z" stroke-linecap="round" stroke-linejoin="round" />
                <circle cx="12" cy="10" r="3" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold">Location</p>
              <p class="text-sm text-inkMuted dark:text-white/60">Coimbatore, Tamil Nadu</p>
            </div>
          </div>
        </div>

        <h4 class="text-base font-semibold mb-2">Let's Connect</h4>
        <p class="text-sm text-inkMuted dark:text-white/60 leading-relaxed mb-5">
          Whether you have an opening, a project in mind, or just want to talk tech, I'd love to hear from you.
        </p>

        <div class="flex flex-wrap items-center gap-3 mt-6">
          {socials.map((s) => (
            <a
              href={s.href}
              target={s.href.startsWith('http') ? '_blank' : undefined}
              rel={s.href.startsWith('http') ? 'noopener' : undefined}
              aria-label={s.label}
              class="flex items-center justify-center w-10 h-10 rounded-lg border border-borderLight dark:border-borderDark text-inkMuted dark:text-white/60 hover:text-ink dark:hover:text-white hover:border-ink/20 dark:hover:border-white/20 transition-colors"
            >
              <svg viewBox="0 0 24 24" class="w-[18px] h-[18px] fill-current"><path d={s.icon}></path></svg>
            </a>
          ))}
          <a
            href="/sugumaran-s-resume.pdf"
            download
            class="inline-flex items-center gap-2 text-sm font-medium px-5 py-2.5 rounded-lg bg-accent dark:bg-accentDark text-white transition-all duration-150 hover:bg-accentHover dark:hover:opacity-90 shadow-card hover:scale-105"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
              <path d="M12 3v12m0 0l-4-4m4 4l4-4M4 19h16" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Download CV
          </a>
        </div>
      </div>

      <ContactForm client:visible />
    </div>
  </section>

  <Footer />
</Layout>
