---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.jsx';
import ContactForm from '../components/ContactForm.jsx';

const coreStack = [
  'Python', 'JavaScript', 'TypeScript', 'React.js', 'Next.js',
  'FastAPI', 'WebSockets', 'Tailwind CSS', 'MySQL', 'MongoDB',
];

const alsoWorkWith = [
  'Flask', 'HTML5 Canvas', 'Scikit-learn', 'NLTK',
  'Hugging Face', 'PostgreSQL', 'SQLite', 'C',
  'Bootstrap', 'Git / GitHub', 'Linux', 'VS Code',
];

const projects = [
  {
    image: 'https://images.unsplash.com/photo-1684707878653-82b2cdab26c5?q=80&w=870&auto=format&fit=crop',
    title: 'Sketchline — Real-Time Collaborative Whiteboard',
    badge: null,
    desc: 'Real-time collaboration without paid SaaS. Built from scratch with FastAPI WebSockets and HTML5 Canvas — no drawing library — achieving sub-100ms stroke latency with normalised coordinates for consistent rendering across screen sizes.',
    tags: ['Next.js', 'TypeScript', 'FastAPI', 'WebSockets'],
    href: 'https://github.com/sugumaran-nix/Sketchline-whiteboard',
    demoHref: 'https://whiteboard-frontend-nine-smoky.vercel.app/',
  },
  {
    image: 'https://images.unsplash.com/photo-1488229297570-58520851e868?w=800&q=80',
    title: 'ML-Powered Fake Job Detector',
    badge: 'Final Year Project',
    desc: 'Fraudulent job listings waste job seekers\' time and erode trust. Screens postings using four ML classifiers and a URL risk scorer, returning explainable predictions in under 800ms — each verdict traces to the exact words that triggered it.',
    tags: ['Python', 'Scikit-Learn', 'NLP', 'Explainable AI'],
    href: 'https://github.com/sugumaran-nix/fake-job-posting-ml',
    demoHref: 'https://fake-job-posting-ml.onrender.com',
  },
  {
    image: 'https://images.unsplash.com/photo-1455390582262-044cdead277a?w=800&q=80',
    title: 'AI-Generated Text Detector',
    badge: null,
    desc: 'Uses perplexity, burstiness, and a trained classifier to distinguish human from AI text, with sentence-level highlighting to show exactly which parts triggered the verdict.',
    tags: ['Python', 'FastAPI', 'NLP', 'Explainable AI'],
    href: 'https://github.com/sugumaran-nix/ai-content-detector',
    demoHref: 'https://ai-content-detector-3u5f.vercel.app/',
  },
  {
    image: 'https://images.unsplash.com/photo-1677506048148-0c914dd8197b?w=800&q=80',
    title: 'ProjectScope',
    badge: null,
    desc: 'Keyboard-accessible Eisenhower Matrix for task prioritization. Drag-and-drop across four quadrants with state that persists and syncs across browser tabs — no backend needed.',
    tags: ['React', 'TypeScript', 'Tailwind CSS', 'dnd-kit'],
    href: 'https://github.com/sugumaran-nix/ProjectScope',
    demoHref: 'https://project-scope-seven.vercel.app',
  },
];

const socials = [
  { label: 'GitHub',   href: 'https://github.com/sugumaran-nix',          icon: 'M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.38.6.1.82-.26.82-.58v-2.03c-3.34.72-4.04-1.61-4.04-1.61-.54-1.38-1.33-1.75-1.33-1.75-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 013-.4c1.02 0 2.04.13 3 .4 2.28-1.55 3.29-1.23 3.29-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.21.69.82.57C20.56 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/sugumaran-nix', icon: 'M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 110-4.14 2.07 2.07 0 010 4.14zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.8 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z' },
  { label: 'Email',    href: 'mailto:sugumarankugan@gmail.com',            icon: 'M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z' },
];
---

<Layout
  title="Sugumaran S — Full Stack Developer & ML Engineer"
  description="MCA graduate building full-stack apps and ML systems with React, FastAPI, and Python. Open to full-time roles."
>
  <Navbar />

  <!-- ── HERO ── -->
  <section id="home" class="min-h-[92vh] flex flex-col items-center justify-center text-center px-6 py-24">
    <div class="reveal max-w-[620px] mx-auto flex flex-col items-center">

      <!-- Badge -->
      <div class="inline-flex items-center gap-2 text-xs font-semibold px-4 py-2 rounded-full border border-accent/40 dark:border-accentDark/40 text-accent dark:text-accentDark bg-accent/5 dark:bg-accentDark/10 mb-8 tracking-wide">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent dark:bg-accentDark opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-accent dark:bg-accentDark"></span>
        </span>
        Open to Full-Time Opportunities
      </div>

      <!-- Name with gradient -->
      <h1 class="text-[48px] md:text-[70px] font-bold leading-[1.02] tracking-tight mb-4">
        I'm{' '}
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-600 to-fuchsia-500 dark:from-violet-400 dark:to-fuchsia-400">
          Sugumaran
        </span>
      </h1>

      <p class="text-xl md:text-2xl font-medium text-inkMuted dark:text-white/60 mb-5">
        Full Stack Developer & ML Engineer
      </p>

      <p class="text-[15px] text-inkMuted dark:text-white/50 leading-relaxed mb-10 max-w-[480px]">
        MCA graduate building real-time collaborative tools and explainable ML systems — from WebSocket-powered canvases to fraud detection classifiers.
      </p>

      <!-- CTAs -->
      <div class="flex items-center gap-3 mb-10">
        <a
          href="#projects"
          class="text-sm font-semibold px-7 py-3 rounded-lg text-white bg-gradient-to-r from-violet-600 to-fuchsia-500 dark:from-violet-500 dark:to-fuchsia-500 hover:opacity-90 transition-opacity shadow-lg shadow-violet-500/25 hover:scale-[1.03] hover:shadow-violet-500/40"
          style="transition: opacity 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease"
        >
          View Projects
        </a>
        <a
          href="/sugumaran-s-resume.pdf"
          download
          class="text-sm font-semibold px-7 py-3 rounded-lg border border-borderLight dark:border-borderDark text-ink dark:text-white hover:bg-black/5 dark:hover:bg-white/5 transition-colors"
        >
          Download CV
        </a>
      </div>

      <!-- Socials -->
      <div class="flex items-center gap-6">
        {socials.map((s) => (
          <a
            href={s.href}
            target={s.href.startsWith('http') ? '_blank' : undefined}
            rel={s.href.startsWith('http') ? 'noopener' : undefined}
            aria-label={s.label}
            class="text-inkMuted dark:text-white/40 hover:text-accent dark:hover:text-accentDark transition-colors"
          >
            <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current"><path d={s.icon} /></svg>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ── ABOUT ── -->
  <section id="about" class="bg-surfaceMuted dark:bg-surfaceDarkMuted px-6 md:px-10 py-20">
    <div class="max-w-5xl mx-auto">
      <div class="reveal mb-12">
        <h2 class="text-3xl md:text-[40px] font-bold tracking-tight">About Me</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center">

        <div class="reveal order-2 md:order-1 flex flex-col gap-5">
          <p class="text-[15px] text-inkMuted dark:text-white/60 leading-[1.9]">
            I'm an MCA graduate from Coimbatore who builds complete, working systems rather than isolated exercises. My final-year project — a multi-model fraud detection system — grew out of a genuine frustration with how easy it is to post fake jobs and mislead desperate job seekers.
          </p>
          <p class="text-[15px] text-inkMuted dark:text-white/60 leading-[1.9]">
            That same instinct drives everything I do: a real-time collaborative whiteboard because shared creative tools should be accessible to everyone, and an AI text detector because understanding what machines generate is increasingly important.
          </p>
          <div class="flex flex-col gap-2.5 pt-1">
            <p class="text-[11px] font-bold uppercase tracking-widest text-accent dark:text-accentDark">Currently</p>
            <ul class="flex flex-col gap-2">
              <li class="flex items-center gap-2.5 text-[13px] text-inkMuted dark:text-white/55">
                <span class="w-1.5 h-1.5 rounded-full bg-gradient-to-br from-violet-500 to-fuchsia-500 flex-shrink-0"></span>
                Deepening knowledge in system design and cloud architecture
              </li>
              <li class="flex items-center gap-2.5 text-[13px] text-inkMuted dark:text-white/55">
                <span class="w-1.5 h-1.5 rounded-full bg-gradient-to-br from-violet-500 to-fuchsia-500 flex-shrink-0"></span>
                Exploring LLM APIs and building AI-powered applications
              </li>
            </ul>
          </div>
        </div>

        <!-- Photo — purple glow in dark mode -->
        <div class="reveal order-1 md:order-2 flex items-center justify-center" style="transition-delay: 0.1s">
          <div class="relative">
            <div class="absolute inset-0 rounded-full bg-gradient-to-br from-violet-500 to-fuchsia-500 opacity-0 dark:opacity-20 blur-2xl scale-110"></div>
            <img
              src="/profile.jpg"
              alt="Sugumaran S"
              class="relative w-56 h-56 md:w-64 md:h-64 rounded-full object-cover ring-2 ring-accent/20 dark:ring-accentDark/30"
            />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── SKILLS ── -->
  <section id="skills" class="px-6 md:px-10 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="reveal mb-10">
        <h2 class="text-3xl md:text-[40px] font-bold tracking-tight">Skills</h2>
      </div>

      <div class="reveal flex flex-col gap-8">

        <div>
          <p class="text-[11px] font-bold uppercase tracking-widest text-accent dark:text-accentDark mb-4">Core Stack</p>
          <div class="flex flex-wrap gap-2">
            {coreStack.map((s) => (
              <span class="text-sm font-medium px-4 py-1.5 rounded-full text-white bg-gradient-to-r from-violet-600 to-fuchsia-500 dark:from-violet-500 dark:to-fuchsia-500 shadow-sm shadow-violet-500/20">
                {s}
              </span>
            ))}
          </div>
        </div>

        <div>
          <p class="text-[11px] font-bold uppercase tracking-widest text-accent dark:text-accentDark mb-4">Also Work With</p>
          <div class="flex flex-wrap gap-2">
            {alsoWorkWith.map((s) => (
              <span class="text-sm px-4 py-1.5 rounded-full border border-accent/30 dark:border-accentDark/30 text-accent dark:text-accentDark">
                {s}
              </span>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── EDUCATION ── -->
  <section id="education" class="bg-surfaceMuted dark:bg-surfaceDarkMuted px-6 md:px-10 py-16">
    <div class="max-w-5xl mx-auto">
      <div class="reveal mb-10">
        <h2 class="text-3xl md:text-[40px] font-bold tracking-tight">Education</h2>
      </div>

      <!-- Timeline -->
      <div class="reveal relative pl-8">

        <!-- Vertical gradient line -->
        <div class="absolute left-[7px] top-2 bottom-2 w-px bg-gradient-to-b from-accent via-accent/40 to-transparent dark:from-accentDark dark:via-accentDark/40"></div>

        <!-- MCA -->
        <div class="relative mb-10">
          <div class="absolute -left-8 top-1 w-4 h-4 rounded-full bg-gradient-to-br from-violet-600 to-fuchsia-500 dark:from-violet-400 dark:to-fuchsia-400 shadow-md shadow-violet-500/40"></div>
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1">
            <div>
              <p class="text-[15px] font-semibold">Master of Computer Applications (MCA)</p>
              <p class="text-sm text-inkMuted dark:text-white/55 mt-1">Sri Venkateshwara College of Computer Applications and Management</p>
              <p class="text-xs text-inkMuted dark:text-white/40 mt-0.5">Anna University</p>
            </div>
            <div class="sm:text-right flex-shrink-0 mt-1">
              <span class="inline-block text-xs font-semibold px-2.5 py-1 rounded-full bg-accent/10 dark:bg-accentDark/15 text-accent dark:text-accentDark">
                2024 – 2026
              </span>
              <p class="text-xs text-inkMuted dark:text-white/40 mt-1.5 sm:text-right">Score: 80%</p>
            </div>
          </div>
        </div>

        <!-- BCA -->
        <div class="relative">
          <div class="absolute -left-8 top-1 w-4 h-4 rounded-full border-2 border-accent dark:border-accentDark bg-surface dark:bg-surfaceDarkMuted"></div>
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1">
            <div>
              <p class="text-[15px] font-semibold">Bachelor of Computer Applications (BCA)</p>
              <p class="text-sm text-inkMuted dark:text-white/55 mt-1">Government Arts & Science College, Gudalur</p>
              <p class="text-xs text-inkMuted dark:text-white/40 mt-0.5">Bharathiar University</p>
            </div>
            <div class="sm:text-right flex-shrink-0 mt-1">
              <span class="inline-block text-xs font-semibold px-2.5 py-1 rounded-full border border-accent/30 dark:border-accentDark/30 text-accent dark:text-accentDark">
                2021 – 2024
              </span>
              <p class="text-xs text-inkMuted dark:text-white/40 mt-1.5 sm:text-right">Score: 83.71%</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── PROJECTS ── -->
  <section id="projects" class="px-6 md:px-10 py-20">
    <div class="max-w-5xl mx-auto">
      <div class="reveal mb-12">
        <h2 class="text-3xl md:text-[40px] font-bold tracking-tight">Projects</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {projects.map((p, i) => (
          <ProjectCard client:visible {...p} delay={i * 0.07} />
        ))}
      </div>

      <div class="mt-10">
        <a
          href="https://github.com/sugumaran-nix"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 text-sm font-medium text-inkMuted dark:text-white/50 hover:text-accent dark:hover:text-accentDark transition-colors"
        >
          <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.38.6.1.82-.26.82-.58v-2.03c-3.34.72-4.04-1.61-4.04-1.61-.54-1.38-1.33-1.75-1.33-1.75-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .1-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 013-.4c1.02 0 2.04.13 3 .4 2.28-1.55 3.29-1.23 3.29-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.21.69.82.57C20.56 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z"/></svg>
          View all projects on GitHub →
        </a>
      </div>
    </div>
  </section>

  <!-- ── CONTACT ── -->
  <section id="contact" class="bg-surfaceMuted dark:bg-surfaceDarkMuted px-6 md:px-10 py-20">
    <div class="max-w-5xl mx-auto">
      <div class="reveal mb-12">
        <h2 class="text-3xl md:text-[40px] font-bold tracking-tight">Get In Touch</h2>
        <p class="text-sm text-inkMuted dark:text-white/45 mt-2">Open to full-time Software Developer and ML Engineer roles.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">

        <!-- Form LEFT -->
        <ContactForm client:visible />

        <!-- Info RIGHT -->
        <div class="reveal flex flex-col gap-5">

          <div class="flex items-start gap-3.5">
            <div class="w-9 h-9 rounded-lg bg-accent/10 dark:bg-accentDark/10 flex items-center justify-center flex-shrink-0">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 text-accent dark:text-accentDark">
                <path d="M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 4l-8 5-8-5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div>
              <p class="text-[11px] font-bold uppercase tracking-widest text-accent dark:text-accentDark mb-0.5">Email</p>
              <a href="mailto:sugumarankugan@gmail.com" class="text-sm hover:text-accent dark:hover:text-accentDark transition-colors">
                sugumarankugan@gmail.com
              </a>
            </div>
          </div>

          <div class="flex items-start gap-3.5">
            <div class="w-9 h-9 rounded-lg bg-accent/10 dark:bg-accentDark/10 flex items-center justify-center flex-shrink-0">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4 text-accent dark:text-accentDark">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1118 0z" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p class="text-[11px] font-bold uppercase tracking-widest text-accent dark:text-accentDark mb-0.5">Location</p>
              <p class="text-sm">Coimbatore, Tamil Nadu</p>
            </div>
          </div>

          <div class="flex flex-wrap items-center gap-2.5 mt-2">
            {socials.map((s) => (
              <a
                href={s.href}
                target={s.href.startsWith('http') ? '_blank' : undefined}
                rel={s.href.startsWith('http') ? 'noopener' : undefined}
                aria-label={s.label}
                class="flex items-center justify-center w-10 h-10 rounded-lg border border-borderLight dark:border-borderDark text-inkMuted dark:text-white/50 hover:text-accent dark:hover:text-accentDark hover:border-accent/30 dark:hover:border-accentDark/30 transition-colors"
              >
                <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current"><path d={s.icon}/></svg>
              </a>
            ))}
            <a
              href="/sugumaran-s-resume.pdf"
              download
              class="inline-flex items-center gap-2 text-sm font-semibold px-5 py-2.5 rounded-lg text-white bg-gradient-to-r from-violet-600 to-fuchsia-500 dark:from-violet-500 dark:to-fuchsia-500 hover:opacity-90 transition-opacity shadow-md shadow-violet-500/25"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
                <path d="M12 3v12m0 0l-4-4m4 4l4-4M4 19h16" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Download CV
            </a>
          </div>

        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
